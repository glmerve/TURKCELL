# ============================================
# RetailCell - Environment Variables
# ============================================

# ---- PostgreSQL (Railway) ----
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/retailcell
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/retailcell

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Kafka / Redis Streams ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
USE_REDIS_STREAMS=true

# ---- Service Ports ----
IDENTITY_SERVICE_PORT=8001
INVENTORY_SERVICE_PORT=8002
AI_SERVICE_PORT=8003
GAMIFICATION_SERVICE_PORT=8004

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---- Railway ----
RAILWAY_ENVIRONMENT=production
PORT=8080
